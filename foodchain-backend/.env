# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=foodchain-local-dev-secret-key-32chars-ok

# ── Database Mode ──────────────────────────────────────────────
# true  = JSON file (demo lokal, tidak perlu PostgreSQL)
# false = PostgreSQL via Prisma (produksi)
USE_JSON_DB=false

# ── PostgreSQL Connection ──────────────────────────────────────
DATABASE_URL="postgresql://foodchain_user:10100101@localhost:5432/foodchain_db"

# Blockchain (mock untuk localhost, isi untuk testnet)
USE_MOCK_BLOCKCHAIN=true
USE_MOCK_IPFS=true
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
RPC_URL=http://127.0.0.1:8545

# Contract addresses (isi setelah deploy smart contract)
CONTRACT_USER_REGISTRY=0x5FbDB2315678afecb367f032d93F642f64180aa3
CONTRACT_STORE_REGISTRY=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
CONTRACT_DONATION_ESCROW=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
CONTRACT_DISPUTE_RESOLUTION=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9

# Pinata IPFS (isi untuk produksi)
PINATA_API_KEY=
PINATA_SECRET_KEY=

USE_JSON_DB=true