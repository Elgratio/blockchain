# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=secret_jwt_key_min_32_chars

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/foodchain"

# Blockchain
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
RPC_URL=http://127.0.0.1:8545          # local hardhat
# RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY  # testnet

# Contract Addresses (diisi setelah deploy)
CONTRACT_USER_REGISTRY=0x...
CONTRACT_STORE_REGISTRY=0x...
CONTRACT_DONATION_ESCROW=0x...
CONTRACT_DISPUTE_RESOLUTION=0x...

# IPFS (Pinata)
PINATA_API_KEY=pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# Firebase (push notification)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com